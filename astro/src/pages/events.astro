---
import Layout from '../layouts/Posts.astro';
import FormattedDate from '../components/FormattedDate.astro';
// import BlogPost from "../components/BlogPost.astro";
const pageTitle = "My Events";
//const allPosts = await Astro.glob("../pages/posts/*.md");
import {getCollection} from "astro:content";
const events = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout pageTitle={pageTitle}>
    <h1>{pageTitle}</h1>
    <ul>
        {
            events.map((event) => (
                    <li style="display: flex; align-items: flex-start; margin-bottom: 20px;">
                        <a href={`/events/${event.slug}/`}
                           style="display: flex; text-decoration: none; color: inherit;">
                            {event.data.image && (
                                    <img
                                            src={event.data.image}
                                            alt={event.data.title}
                                            style={{
                                                width: '100px',
                                                height: '100px',
                                                marginRight: '15px',
                                                flexShrink: 0,
                                                borderRadius: '50%',
                                                objectFit: 'cover'
                                            }}
                                    />
                            )}
                        </a>
                        <div>
                            <a href={`/events/${event.slug}/`}>
                                <h4 class="title" style="margin: 0;">
                                    {event.data.title}
                                </h4>
                            </a>
                            <p style="margin: 0; font-size: 0.9em; color: gray;">
                                <FormattedDate date={event.data.pubDate}/>
                            </p>
                        </div>
                    </li>
            ))
        }
    </ul>
</Layout>