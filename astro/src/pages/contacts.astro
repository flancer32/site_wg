---
import Layout from '../layouts/Layout.astro';
const pageTitle = "Contact Me";
---
<Layout pageTitle={pageTitle}>
    <h1>{pageTitle}</h1>
    <div class="contacts-grid">
        <article class="links">
            <h2>Email & Messengers</h2>
            <ul>
                <li>
                    <a href="mailto:alex@wiredgeese.com">
                        <img src="/img/contacts/email.svg" alt="Email"/>
                        <span>mailto:alex@wiredgeese.com</span>
                    </a>
                </li>
                <li>
                    <a href="https://wa.me/37129181801" target="_blank" rel="noopener noreferrer">
                        <img src="/img/contacts/whatsapp.svg" alt="WhatsApp"/>
                        <span>+371 29181801</span>
                    </a>
                </li>
                <li>
                    <a href="https://t.me/wiredgeese" target="_blank">
                        <img src="/img/contacts/telegram.svg" alt="Telegram"/>
                        <span>@wiredgeese</span>
                    </a>
                </li>
            </ul>
        </article>

        <article class="links">
            <h2>My Links</h2>
            <ul>
                <li><a href="https://github.com/flancer64"><img src="/img/contacts/github.svg" alt="GitHub"/><span>GitHub</span></a>
                </li>
                <li><a href="https://stackoverflow.com/users/4073821/alex-gusev"><img
                        src="/img/contacts/stackoverflow.svg" alt="StackOverflow"/><span>StackOverflow</span></a></li>
                <li><a href="https://flancer32.com/"><img src="/img/contacts/medium.svg"
                                                          alt="Medium"/><span>Medium</span></a></li>
                <li><a href="https://www.linkedin.com/in/aleksandrs-gusevs-011ba928/"><img
                        src="/img/contacts/linkedin.svg" alt="LinkedIn"/><span>LinkedIn</span></a></li>
                <li><a href="https://www.upwork.com/freelancers/~0181de0a64c6981497"><img src="/img/contacts/upwork.svg"
                                                                                          alt="Upwork"/><span>Upwork</span></a>
                </li>
                <li><a href="https://www.fiverr.com/users/wiredgeese"><img src="/img/contacts/fiverr.svg" alt="Fiverr"/><span>Fiverr</span></a>
                </li>
            </ul>
        </article>

        <article class="company">
            <h2>My Company</h2>
            <div class="table">
                <div>Company Name:</div>
                <div>F. Lancer</div>
                <div>Company Registration Number:</div>
                <div>40103303120 <span class="since">(since 2010/06/29)</span></div>
                <div>SEPA Identifier:</div>
                <div>LV82ZZZ40103303120</div>
                <div>VAT Number:</div>
                <div>LV40103303120 <span class="since">(since 2023/09/27)</span></div>
                <div>Bank Account Number:</div>
                <div>LV83HABA0551028650868</div>
            </div>
        </article>
    </div>
</Layout>

<style>
    .contacts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        padding: 20px;
    }

    .links, .company {
        border: 1px solid #4CAF50;
        border-radius: 8px;
        background-color: #1A1A1A;
        padding: 15px;
        color: #E0E0E0;
    }

    .links ul {
        list-style-type: none;
        padding: 0;
    }

    .links ul li {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

    .links ul li img {
        width: 40px;
        height: 40px;
        margin-right: 15px;
        border-radius: 50%;
        background-color: #ffffff;
    }

    .links ul li a {
        display: flex;
        align-items: center;
        text-decoration: none;
        color: inherit;
        transition: transform 0.3s ease, color 0.3s ease;
    }

    .links ul li a:hover {
        transform: scale(1.05);
        color: #81C784;
    }

    .company .table {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
    }

    .company .since {
        font-size: 0.8rem;
        color: #81C784;
    }

</style>