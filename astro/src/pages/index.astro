---
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import {getCollection} from 'astro:content';

const events = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---
<Layout title="Alex Gusev | Advanced Web Applications & Bot Development">
    <section class="hero">
        <div class="hero-content">
            <h1>Your Web Apps Connected to the Future</h1>
            <p>
                Creating innovative web applications integrated with
                <strong>Telegram</strong> and <strong>ChatGPT</strong>.
            </p>
        </div>
    </section>
    <section>
        <h2>Recent Events</h2>
        <ul style="list-style-type: none; padding: 0;">
            {events.slice(0, 5).map((event) => (
                    <li style="display: flex; align-items: flex-start; margin-bottom: 20px;">
                        <a href={`/events/${event.slug}/`}
                           style="display: flex; text-decoration: none; color: inherit;">
                            {event.data.image && (
                                    <img
                                            src={event.data.image}
                                            alt={event.data.title}
                                            style={{width: '100px', marginRight: '15px', flexShrink: 0}}
                                    />
                            )}
                        </a>
                        <div>
                            <a href={`/events/${event.slug}/`} style="text-decoration: none; color: inherit;">
                                <h4 class="title" style="margin: 0;">
                                    {event.data.title}
                                </h4>
                            </a>
                            <p style="margin: 0; font-size: 0.9em; color: gray;">
                                <FormattedDate date={event.data.pubDate}/>
                            </p>
                        </div>
                    </li>
            ))}
        </ul>
    </section>
</Layout>

<style>
    .hero {
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 50px 20px;
        background: linear-gradient(145deg, #121212, #1F1F1F);
    }

    .hero h1 {
        font-size: 2.5rem;
        margin-bottom: 20px;
    }

    .hero p {
        font-size: 1.1rem;
        margin-bottom: 20px;
        color: #81C784;
    }
</style>