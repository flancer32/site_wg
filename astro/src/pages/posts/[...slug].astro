---
import {getEntryBySlug, getCollection} from 'astro:content';
import Layout from '../../layouts/Posts.astro';

export async function getStaticPaths() {
    // Fetch all posts from the 'posts' collection
    const posts = await getCollection('posts');
    return posts.map((post) => ({
        params: {slug: post.slug},
        props: {post}, // Pass the post data as props
    }));
}

const {post} = Astro.props; // Extract the post passed as a prop
const {title, description, pubDate, image} = post.data;
const {Content} = await post.render();
---
<Layout title={title}>
    <Content/>
</Layout>