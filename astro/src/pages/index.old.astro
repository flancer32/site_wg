---
import HomeLayout from '../layouts/home.astro';
import FormattedDate from '../components/FormattedDate.astro';
import {getCollection} from 'astro:content';

const events = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<HomeLayout>
    <section>
        <h2>Recent Events</h2>
        <ul style="list-style-type: none; padding: 0;">
            {events.slice(0, 5).map((event) => (
                    <li style="display: flex; align-items: flex-start; margin-bottom: 20px;">
                        <a href={`/events/${event.slug}/`}
                           style="display: flex; text-decoration: none; color: inherit;">
                            {event.data.image && (
                                    <img
                                            src={event.data.image}
                                            alt={event.data.title}
                                            style={{width: '100px', marginRight: '15px', flexShrink: 0}}
                                    />
                            )}
                        </a>
                        <div>
                            <a href={`/events/${event.slug}/`} style="text-decoration: none; color: inherit;">
                                <h4 class="title" style="margin: 0;">
                                    {event.data.title}
                                </h4>
                            </a>
                            <p style="margin: 0; font-size: 0.9em; color: gray;">
                                <FormattedDate date={event.data.pubDate}/>
                            </p>
                        </div>
                    </li>
            ))}
        </ul>
    </section>

</HomeLayout>

