<script>
    // Various analytic trackers
    if (location.hostname === 'wiredgeese.com') {
        /* Google Analytics */
        {
            // prepare environment to load GA script
            const GA_CODE = 'G-48WM3FE8HL';
            window.dataLayer = window.dataLayer || [];

            function gtag() {
                dataLayer.push(arguments);
            }

            gtag('js', new Date());
            gtag('config', GA_CODE);
            // append SCRIPT tag to HEAD and start loading of GA script
            const elScript = document.createElement('script');
            elScript.src = `https://www.googletagmanager.com/gtag/js?id=${GA_CODE}`;
            document.getElementsByTagName('head')[0].appendChild(elScript);
        }

        /* Matomo */
        {
            let _paq = window._paq = window._paq || [];
            /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
            _paq.push(['trackPageView']);
            _paq.push(['enableLinkTracking']);
            (function () {
                let u = "//matomo.service.wiredgeese.com/";
                _paq.push(['setTrackerUrl', u + 'matomo.php']);
                _paq.push(['setSiteId', '3']);
                let d = document, g = d.createElement('script'), s = d.getElementsByTagName('script')[0];
                g.async = true;
                g.src = u + 'matomo.js';
                s.parentNode.insertBefore(g, s);
            })();
        }
    }

</script>