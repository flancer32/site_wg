---
import '../styles/global.css';
import '../styles/layout/event.css';
import {SITE_TITLE, SITE_DESCRIPTION} from '../consts';
import Links from '../components/Links.astro';
import Stats from '../components/Stats.astro';
---
<script is:inline type="module">
    import FBigImage from '/components/AppBigImage.mjs';
    import FFooter from '/pcomponents/AppFooter.mjs';
    import FHeader from '/components/AppHeader.mjs';
    import FMenu from '/components/AppMenu.mjs';

    // create and register web-components in browser mode (not in SSR mode)
    if (typeof window !== 'undefined') {
        FBigImage();
        FFooter();
        FHeader();
        FMenu();
    }
</script>

<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://fonts.googleapis.com/css2?family=Roboto&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{SITE_TITLE}</title>
    <Stats/>
</head>
<body>
<header class="no-print">
    <div>
        <a href="/" title="Homepage" style="display: flex; align-items: center">
            <img src="https://gravatar.com/userimage/144345089/fc8f81bd3bcc05389f1241f7d8ff2868.jpeg" alt="Your Avatar"
                 class="avatar">
        </a></div>
    <nav>
        <Links/>
    </nav>
</header>

<main>
    <div class="content-area">
        <slot></slot>
    </div>
</main>

<footer class="no-print">
    <app-footer></app-footer>
</footer>
</body>
</html>