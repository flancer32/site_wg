---
import '../styles/global.css';
import '../styles/layout/home.css';
import '../styles/components/app-menu.css';
import Links from '../components/Links.astro';
import Stats from '../components/Stats.astro';
---
<script is:inline type="module">
    import FBigImage from '/components/AppBigImage.mjs';
    import FFooter from '/components/AppFooter.mjs';
    import FHeader from '/components/AppHeader.mjs';
    import FMenu from '/components/AppMenu.mjs';

    // create and register web-components in browser mode (not in SSR mode)
    if (typeof window !== 'undefined') {
        FBigImage();
        FFooter();
        FHeader();
        FMenu();
    }
</script>

<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://fonts.googleapis.com/css2?family=Roboto&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Personal Website</title>
    <Stats/>
</head>
<body>
<div class="intro">
    <div class="content">
        <h1 class="slogan">
            Experience web apps like never before with PWA
        </h1>
        <h4>Complex issues bear multiple solutions; their optimum is in the eye of the assessor.</h4>
        <img src="https://gravatar.com/userimage/144345089/fc8f81bd3bcc05389f1241f7d8ff2868.jpeg" alt="My Avatar"
             class="avatar">
    </div>
</div>
<app-big-image></app-big-image>
<header>
    <app-menu>
        <nav>
            <Links/>
        </nav>
    </app-menu>
</header>


<main>
    <div class="content-area">
        <slot></slot>
    </div>
</main>

<footer>
    <app-footer></app-footer>
</footer>
</body>
</html>