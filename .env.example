# Copy this file to `.env` and adjust values for your local environment.

# Local web server settings
TEQ_CMS_BASE_URL=http://127.0.0.1:3000
TEQ_CMS_SERVER_PORT=3000
TEQ_CMS_SERVER_TYPE=http

# Locale settings
TEQ_CMS_LOCALE_ALLOWED=en,es,ru
TEQ_CMS_LOCALE_BASE_TRANSLATE=ru
TEQ_CMS_LOCALE_BASE_DISPLAY=en

# Optional template engine override
# TEQ_CMS_TMPL_ENGINE=nunjucks

# Optional AI translation settings
# TEQ_CMS_AI_API_BASE_URL=
# TEQ_CMS_AI_API_KEY=
# TEQ_CMS_AI_API_MODEL=
# TEQ_CMS_AI_API_ORG=

# Email settings for the contact form handler
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_TO=Alex Gusev <alex@wiredgeese.com>
# EMAIL_AUTH_USER=your-email@gmail.com
# EMAIL_AUTH_PASS=your-app-password
